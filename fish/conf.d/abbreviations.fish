# ╔══════════════════════════════════════════╗
# ║           PHP Artisan Shortcuts          ║
# ╚══════════════════════════════════════════╝
abbr -a pa    'php artisan'
abbr -a pas   'php artisan serve'
abbr -a pat   'php artisan tinker'
abbr -a par   'php artisan route:list'
abbr -a pam   'php artisan migrate'
abbr -a pamf  'php artisan migrate:fresh'
abbr -a pamfs 'php artisan migrate:fresh --seed'
abbr -a pams  'php artisan migrate:status'
abbr -a pacc  'php artisan cache:clear'
abbr -a pacca 'php artisan config:cache'
abbr -a parc  'php artisan route:cache'
abbr -a pak   'php artisan key:generate'
abbr -a paq   'php artisan queue:work'
abbr -a paql  'php artisan queue:listen'
# make:*
abbr -a pamc  'php artisan make:controller'
abbr -a pamm  'php artisan make:model'
abbr -a pamig 'php artisan make:migration'
abbr -a pamse 'php artisan make:seeder'
abbr -a pamrq 'php artisan make:request'
abbr -a pammd 'php artisan make:middleware'
abbr -a mampo 'php artisan make:policy'
abbr -a mamev 'php artisan make:event'
abbr -a mamli 'php artisan make:listener'
abbr -a mamjo 'php artisan make:job'

# ╔══════════════════════════════════════════╗
# ║              npm Shortcuts               ║
# ╚══════════════════════════════════════════╝
abbr -a ni    'npm install'
abbr -a nid   'npm install -D'
abbr -a nig   'npm install -g'
abbr -a nu    'npm update'
abbr -a nrm   'npm remove'
abbr -a nr    'npm run'
abbr -a nrd   'npm run dev'
abbr -a nrb   'npm run build'
abbr -a nrs   'npm run start'
abbr -a nrt   'npm run test'
abbr -a nrl   'npm run lint'
abbr -a nlg   'npm list -g --depth=0'

